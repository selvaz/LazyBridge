<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title|e }}</title>
  <style>{{ css }}</style>
  <style>
    .report-header {
      margin-bottom: 40px;
      padding-bottom: 28px;
      border-bottom: 2px solid var(--border, #e0e0e0);
    }
    .report-header h1 {
      margin: 0 0 14px;
      padding: 0;
      border: none;
      font-size: 2.2em;
      letter-spacing: -0.04em;
    }
    .report-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .meta-chip {
      display: inline-flex;
      align-items: center;
      padding: 4px 12px;
      font-size: 0.78em;
      font-weight: 600;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: var(--accent, #1f4e79);
      background: var(--accent-soft, #e8f1f8);
      border-radius: 999px;
    }
    .report-footer {
      margin-top: 56px;
      padding-top: 20px;
      border-top: 1px solid var(--border, #e0e0e0);
      font-size: 0.82em;
      color: var(--muted, #888);
      display: flex;
      justify-content: space-between;
    }
  </style>
</head>
<body>
  <main class="report-shell">
    <header class="report-header">
      <h1>{{ title|e }}</h1>
      <div class="report-meta">
        <span class="meta-chip">{{ meta.generated_at }}</span>
        <span class="meta-chip">{{ meta.theme }}</span>
        {% if meta.charts_embedded > 0 %}
        <span class="meta-chip">{{ meta.charts_embedded }} chart{{ 's' if meta.charts_embedded != 1 else '' }}</span>
        {% endif %}
      </div>
    </header>
    <article class="markdown-body">
{{ body_html }}
    </article>
    <footer class="report-footer">
      <span>Generated {{ meta.generated_at }}</span>
      <span>{{ meta.template }} · {{ meta.theme }}</span>
    </footer>
  </main>
</body>
</html>
